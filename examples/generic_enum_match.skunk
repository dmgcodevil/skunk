enum Option[T] {
    None;
    Some(T);
}

function unwrap(value: Option[int]): int {
    match (value) {
        case None: {
            return 0;
        }
        case Some(v): {
            return v + 1;
        }
    }
}

function main(): void {
    print(unwrap(Option[int]::None()));
    print(unwrap(Option[int]::Some(41)));
}
