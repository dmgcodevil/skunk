function fib(n: int): int {
    if (n <= 1) {
        return n;
    } else {
        return fib(n - 1) + fib(n - 2);
    }
}

function main(): void {
    limit: int = 35;
    i: int = 0;
    total: int = 0;

    for (i: int = 0; i < limit; i = i + 1) {
        total = total + fib(i);
    }

    print(total);
}
